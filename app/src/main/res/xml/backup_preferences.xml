<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:singleLineTitle="false"
        app:title="@string/backup_restore">

        <Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_backup_action"
            app:title="@string/backup" />

        <Preference
            app:iconSpaceReserved="false"
            app:key="@string/pref_restore_action"
            app:title="@string/restore" />

        <SwitchPreferenceCompat
            app:defaultValue="false"
            app:iconSpaceReserved="false"
            app:key="@string/pref_auto_backup_enabled"
            app:singleLineTitle="false"
            app:title="@string/automatic_backup" />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="@string/pref_include_mapsforge_backups"
            app:singleLineTitle="false"
            app:summary="@string/include_mapsforge_backups_summary"
            app:title="@string/include_mapsforge_backups" />

    </PreferenceCategory>
</PreferenceScreen>
