        e="way"
        k="leisure"
        v="recreation_ground|park"
        zoom-min="16"
    >
        <caption
            fill="#000000"
            font-family="serif"
            font-size="14"
            font-style="italic"
            k="name"
            stroke="#FFFFFF"
            stroke-width="2.0"
        />
    </rule> -->

    <!-- Public land labels -->
    <rule
        e="node"
        k="trail_sense_area_label"
        v="yes"
        zoom-min="13"
    >
        <rule
            e="node"
            k="boundary|leisure"
            v="protected_area|national_park|nature_reserve"
            zoom-min="13">
            <caption
                fill="#47742c"
                font-size="16"
                font-style="bold"
                k="name"
                stroke="#FFFFFF"
                stroke-width="2.0"
                position="center"
                priority="0"
            />
        </rule>
    </rule>

    <!-- Water labels -->
    <rule e="way" k="waterway" v="river" zoom-min="12">
        <pathText
            display="order"
            fill="#4E8CA8"
            font-size="14"
            font-style="bold"
            k="name"
            priority="-100"
            stroke="#FFFFFF"
            stroke-width="2.0"
            dy="3"
        />
    </rule>

    <rule e="way" k="waterway" v="stream|canal|drain" zoom-min="15">
        <pathText
            display="order"
            fill="#4E8CA8"
            font-size="12"
            k="name"
            priority="-100"
            stroke="#FFFFFF"
            stroke-width="2.0"
            dy="2"
        />
    </rule>

    <rule
        e="node"
        k="trail_sense_area_label"
        v="yes"
        zoom-min="14"
    >
        <rule e="node" k="natural|landuse" v="water|reservoir|basin" zoom-min="14">
            <caption
                display="order"
                fill="#4E8CA8"
                font-size="14"
                font-style="bold"
                k="name"
                priority="-100"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
    </rule>

    <!-- Highway labels -->
    <rule e="way" k="tunnel" v="~|no|false">
        <rule
            e="way"
            k="highway"
            v="footway|path|track|bridleway|steps|byway"
            zoom-min="14"
        >
            <pathText
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                priority="-8"
                stroke="#FFFFFF"
                stroke-width="2"
                dy="2"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="cycleway|service|services|raceway|construction|road|pedestrian|unclassified|residential|living_street|tertiary|tertiary_link|bus_guideway"
            zoom-min="16"
        >
            <pathText
                fill="#000000"
                font-size="10"
                font-style="bold"
                k="name"
                priority="-7"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="secondary_link|primary_link|trunk_link|motorway_link|secondary|primary"
            zoom-min="15"
        >
            <pathText
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                priority="-6"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="any"
            k="highway"
            v="trunk|primary|secondary|tertiary"
            zoom-min="12"
        >
            <rule e="way" k="name" v="~">
                <pathText
                    fill="#000000"
                    font-size="14"
                    font-style="bold"
                    k="ref"
                    priority="-5"
                    stroke="#FFFFFF"
                    stroke-width="3.0"
                />
            </rule>
        </rule>
        <rule e="any" k="highway" v="motorway" zoom-min="12">
            <pathText
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="ref"
                priority="-4"
                stroke="#FFFFFF"
                stroke-width="3.0"
            />
        </rule>
    </rule>

    <!-- Place labels -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="place" v="locality" zoom-min="14">
            <rule e="any" k="mountain_pass|natural|tourism" v="~">
                <caption
                    fill="#000000"
                    font-family="serif"
                    font-size="12"
                    font-style="italic"
                    k="name"
                    priority="10"
                    stroke="#FFFFFF"
                    stroke-width="0.1"
                />
            </rule>
        </rule>
        <rule e="node" k="place" v="island|islet" zoom-min="14">
            <caption
                fill="#000000"
                font-family="serif"
                font-size="12"
                font-style="italic"
                k="name"
                priority="30"
                stroke="#FFFFFF"
                stroke-width="0.1"
            />
        </rule>
        <rule e="node" k="place" v="suburb" zoom-min="13">
            <caption
                fill="#000000"
                font-family="serif"
                font-size="14"
                font-style="bold_italic"
                k="name"
                priority="20"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="node"
            k="place"
            v="isolated_dwelling|neighbourhood"
            zoom-min="15"
        >
            <caption
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                priority="5"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="hamlet" zoom-min="14">
            <caption
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                priority="5"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="village" zoom-min="12">
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                priority="20"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="town" zoom-min="8">
            <caption
                fill="#000000"
                font-size="16"
                font-style="bold"
                k="name"
                priority="30"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="6" zoom-min="6">
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="7" zoom-min="7">
            <caption
                fill="#000000"
                font-size="15"
                font-style="bold"
                k="name"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="9" zoom-min="8">
            <caption
                fill="#000000"
                font-size="17"
                font-style="bold"
                k="name"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="11" zoom-min="10">
            <caption
                fill="#000000"
                font-size="19"
                font-style="bold"
                k="name"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="13" zoom-min="12">
            <caption
                fill="#000000"
                font-size="20"
                font-style="bold"
                k="name"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="3">
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="4" zoom-min="4">
            <caption
                fill="#000000"
                font-size="16"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="5" zoom-min="5">
            <caption
                fill="#000000"
                font-size="18"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="6" zoom-min="6">
            <caption
                fill="#000000"
                font-size="20"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
    </rule>

    <!-- ================ POIS ================ -->

    <!-- Natural landmarks -->
    <rule e="any" k="*" v="*">
        <rule e="node" k="natural" v="cave_entrance" zoom-min="14">
            <!-- TODO: Icon needed -->
            <symbol
                id="cave"
                src="@drawable/ic_category_shelter#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="10"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="cave"
                />
            </rule>
        </rule>
        <rule e="node" k="natural" v="peak" zoom-min="9">
            <symbol
                id="peak"
                src="@drawable/triangle#000000!"
                symbol-height="12"
                symbol-width="12"
                display="always"
            />
            <trail_sense_peak_elevation_captions />
        </rule>
        <rule e="node" k="natural" v="volcano" zoom-min="11">
            <symbol
                id="volcano"
                src="@drawable/volcano#000000"
                symbol-height="12"
                symbol-width="12"
            />
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                position="above"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="volcano"
            />
        </rule>
