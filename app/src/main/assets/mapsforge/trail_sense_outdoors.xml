<?xml version="1.0" encoding="UTF-8"?>
<!-- https://github.com/mapsforge/mapsforge/blob/master/mapsforge-map-writer/src/main/config/tag-mapping.xml -->
<rendertheme
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    map-background="#C4CCB0"
    map-background-outside="#C4CCB0"
    version="5"
    xmlns="http://mapsforge.org/renderTheme"
    xsi:schemaLocation="http://mapsforge.org/renderTheme https://raw.githubusercontent.com/mapsforge/mapsforge/master/resources/renderTheme.xsd"
>

    <!-- ================ NATURAL / LANDUSE ================ -->

    <rule e="way" k="natural|landuse" v="sea" zoom-min="0">
        <area fill="#AAD3DF" />
    </rule>

    <!-- Land -->
    <rule e="way" k="natural" v="nosea|land" zoom-min="0">
        <area fill="#C4CCB0" />
    </rule>

    <!-- Sand -->
    <rule
        e="way"
        k="natural|landuse|surface"
        v="beach|sand|desert|dune"
        zoom-min="6"
    >
        <area fill="#E8E1B6" />
    </rule>

    <!-- Rock -->
    <rule
        e="way"
        k="natural|landuse|surface"
        v="scree|shingle|gravel|quarry|bare_rock|pebbles|stones|blockfield|rock"
        zoom-min="6"
    >
        <area fill="#CAC3B8" />
    </rule>

    <rule e="way" k="natural|wetland" v="mud" zoom-min="6">
        <area fill="#BFC7B7" />
    </rule>

    <!-- Tundra -->
    <rule e="way" k="natural" v="tundra|fell" zoom-min="6">
        <area fill="#BEC7AA" />
    </rule>

    <!-- Grassland / herbaceous -->
    <rule
        e="way"
        k="natural|surface"
        v="grassland|meadow|grass"
        zoom-min="6"
    >
        <area fill="#BBC6A8" />
    </rule>

    <!-- Scrub -->
    <rule
        e="way"
        k="natural"
        v="heath|scrub|shrub"
        zoom-min="6"
    >
        <area fill="#B8C3A1" />
    </rule>

    <!-- Trees -->
    <rule e="way" k="natural|landuse" v="wood|forest" zoom-min="6">
        <area fill="#B5C6A2" />
    </rule>

    <!-- Buildings -->
    <rule e="way" k="building" v="*" zoom-min="16">
        <area fill="#B8B8B0" />
        <line stroke="#22000000" stroke-width="0.1" />
    </rule>

    <!-- Wetlands -->
    <rule e="way" k="natural" v="marsh|wetland" zoom-min="6">
        <area fill="#B1CCB8" />
        <area
            src="@drawable/swamp_pattern#6F9781!"
            symbol-height="24"
            symbol-width="24"
        />
    </rule>

    <!-- Major bodies of water -->

    <rule e="way" k="natural|landuse" v="water|basin|reservoir" zoom-min="0">
        <area fill="#AAD3DF" />
        <line stroke="#4E8CA8" stroke-width="0.3" />
    </rule>

    <rule e="way" k="waterway" v="river|riverbank" zoom-min="8">
        <line stroke="#4E8CA8" stroke-width="1.0" />
    </rule>

    <!-- Minor bodies of water -->
    <rule e="way" k="waterway" v="canal|drain|stream" zoom-min="10">
        <line stroke="#4E8CA8" stroke-width="0.5" />
    </rule>

    <!-- Perennial Ice/Snow -->
    <rule e="way" k="natural" v="glacier" zoom-min="8">
        <area fill="#F5F4F2" />
    </rule>

    <!-- Public lands: https://wiki.openstreetmap.org/wiki/United_States/Public_lands -->

    <rule
        e="way"
        k="boundary|leisure"
        v="protected_area|national_park|nature_reserve"
        zoom-min="10"
    >
        <rule e="way" k="access" v="~|yes|public|permissive|designated">
            <line dy="1.0" stroke="#4475A35B" stroke-width="2.0" />
            <line stroke="#47742C" stroke-width="0.5" />
        </rule>
    </rule>

    <!-- Water control features -->
    <rule e="way" k="waterway" v="dam" zoom-min="14">
        <line stroke="#8E8E87" stroke-width="1" />
        <line
            stroke="#C8C0B0"
            stroke-dasharray="10,1"
            stroke-linecap="butt"
            stroke-width="1"
        />
        <rule closed="yes" e="any" k="*" v="*">
            <area fill="#C8C0B0" />
        </rule>
    </rule>

    <!-- ================ WAY -> HIGHWAY ================ -->

    <!-- Access roads -->
    <rule e="way" k="highway" v="service|services" zoom-min="15">
        <line stroke="#AAA8A0" stroke-width="0.5" />
        <line stroke="#D4D0C4" stroke-width="0.3" />
    </rule>

    <!-- Backcountry tracks -->
    <rule e="way" k="highway" v="byway|track" zoom-min="12">
        <line stroke="#8E6A3F" stroke-width="1.1" />
        <line stroke="#D6C595" stroke-width="0.8" />
        <line
            stroke="#8E6A3F"
            stroke-width="0.45"
            stroke-dasharray="3,2"
            scale="all"
        />
    </rule>

    <!-- Minor roads -->
    <rule
        e="way"
        k="highway"
        v="residential|road|unclassified|living_street|pedestrian"
        zoom-min="12"
    >
        <line stroke="#AAA8A0" stroke-width="0.9" />
        <line stroke="#D4D0C4" stroke-width="0.7" />
    </rule>

    <rule e="way" k="highway" v="tertiary|tertiary_link" zoom-min="11">
        <line stroke="#8E8E87" stroke-width="1.2" />
        <line stroke="#C9C4B8" stroke-width="1.0" />
    </rule>

    <!-- Major roads -->
    <rule e="way" k="highway" v="secondary|secondary_link" zoom-min="11">
        <line stroke="#7C7C75" stroke-width="1.4" />
        <line stroke="#B9B4A8" stroke-width="1.2" />
    </rule>

    <rule e="way" k="highway" v="primary|primary_link" zoom-min="11">
        <line stroke="#7C7C75" stroke-width="1.6" />
        <line stroke="#B9B4A8" stroke-width="1.4" />
    </rule>

    <rule
        e="way"
        k="highway"
        v="trunk|trunk_link|motorway|motorway_link"
        zoom-min="10"
    >
        <line stroke="#74746E" stroke-width="2.0" />
        <line stroke="#AAA69C" stroke-width="1.8" />
    </rule>

    <!-- Bike paths -->
    <rule e="way" k="highway" v="cycleway" zoom-min="12">
        <line
            stroke="#7A7250"
            stroke-width="0.4"
            stroke-dasharray="2,2"
            scale="all"
        />
    </rule>

    <!-- Trails -->
    <rule
        e="way"
        k="highway"
        v="path|bridleway"
        zoom-min="12"
    >
        <line
            stroke="#6B3F1D"
            stroke-width="0.7"
            stroke-dasharray="1,1"
            scale="all"
        />
    </rule>

    <!-- Sidewalks / Steps -->
    <rule
        e="way"
        k="highway"
        v="footway"
        zoom-min="12"
    >
        <line
            stroke="#73592E"
            stroke-width="0.4"
            stroke-dasharray="1,1"
            scale="all"
        />
    </rule>

    <rule e="way" k="highway" v="steps" zoom-min="15">
        <line
            stroke="#73592E"
            stroke-width="0.4"
            stroke-dasharray="1,1"
            scale="all"
        />
    </rule>

    <rule e="way" k="access" v="private|no">
        <rule
            e="way"
            k="highway"
            v="path|footway|bridleway|track|byway|cycleway|steps"
            zoom-min="12"
        >
            <line
                stroke="#7F7468"
                stroke-width="0.7"
                stroke-dasharray="1,3"
                scale="all"
            />
        </rule>
    </rule>

    <!-- ================ LABELS ================ -->

    <!-- Public land labels -->
    <rule
        e="node"
        k="trail_sense_area_label"
        v="yes"
        zoom-min="13"
    >
        <rule
            e="node"
            k="boundary|leisure"
            v="protected_area|national_park|nature_reserve"
            zoom-min="13">
            <rule e="node" k="access" v="~|yes|public|permissive|designated">
                <caption
                    fill="#47742c"
                    font-family="serif"
                    font-size="15"
                    font-style="italic"
                    k="name"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    position="center"
                    priority="15"
                />
            </rule>
        </rule>
    </rule>

    <!-- Water labels -->
    <rule e="way" k="waterway" v="river" zoom-min="12">
        <pathText
            display="order"
            fill="#4E8CA8"
            font-size="14"
            font-style="italic"
            k="name"
            priority="20"
            stroke="#FFFFFF"
            stroke-width="2.0"
            dy="3"
        />
    </rule>

    <rule e="way" k="waterway" v="stream|canal|drain" zoom-min="15">
        <pathText
            display="order"
            fill="#4E8CA8"
            font-size="12"
            font-style="italic"
            k="name"
            priority="12"
            stroke="#FFFFFF"
            stroke-width="2.0"
            dy="2"
        />
    </rule>

    <rule
        e="node"
        k="trail_sense_area_label"
        v="yes"
        zoom-min="14"
    >
        <rule e="node" k="natural|landuse" v="water|reservoir|basin" zoom-min="14">
            <caption
                display="order"
                fill="#4E8CA8"
                font-size="14"
                font-style="italic"
                k="name"
                priority="20"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
    </rule>

    <!-- Highway labels -->
    <rule e="way" k="tunnel" v="~|no|false">
        <rule
            e="way"
            k="highway"
            v="footway|path|bridleway|steps"
            zoom-min="14"
        >
            <pathText
                fill="#5A341B"
                font-size="12"
                font-style="bold"
                k="name"
                priority="35"
                stroke="#FFFFFF"
                stroke-width="2"
                dy="2"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="track|byway"
            zoom-min="14"
        >
            <pathText
                fill="#704F29"
                font-size="11"
                font-style="bold"
                k="name"
                priority="24"
                stroke="#FFFFFF"
                stroke-width="2"
                dy="2"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="cycleway"
            zoom-min="16"
        >
            <pathText
                fill="#625B42"
                font-size="10"
                font-style="bold"
                k="name"
                priority="6"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="residential|road|unclassified|living_street|tertiary|tertiary_link"
            zoom-min="16"
        >
            <pathText
                fill="#4E4E49"
                font-size="10"
                k="name"
                priority="-10"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="way"
            k="highway"
            v="secondary_link|primary_link|trunk_link|motorway_link|secondary|primary|trunk|motorway"
            zoom-min="15"
        >
            <pathText
                fill="#4E4E49"
                font-size="11"
                k="name"
                priority="-8"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule
            e="any"
            k="highway"
            v="trunk|primary|secondary|tertiary"
            zoom-min="12"
        >
            <rule e="way" k="name" v="~">
                <pathText
                    fill="#4E4E49"
                    font-size="11"
                    font-style="bold"
                    k="ref"
                    priority="-6"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                />
            </rule>
        </rule>
        <rule e="any" k="highway" v="motorway" zoom-min="12">
            <pathText
                fill="#4E4E49"
                font-size="11"
                font-style="bold"
                k="ref"
                priority="-5"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
    </rule>

    <!-- Place labels -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="place" v="locality" zoom-min="14">
            <rule e="any" k="mountain_pass|natural|tourism" v="~">
                <caption
                    fill="#000000"
                    font-family="serif"
                    font-size="12"
                    font-style="italic"
                    k="name"
                    priority="10"
                    stroke="#FFFFFF"
                    stroke-width="0.1"
                />
            </rule>
        </rule>
        <rule e="node" k="place" v="island|islet" zoom-min="14">
            <caption
                fill="#000000"
                font-family="serif"
                font-size="12"
                font-style="italic"
                k="name"
                priority="30"
                stroke="#FFFFFF"
                stroke-width="0.1"
            />
        </rule>
        <rule e="node" k="place" v="hamlet" zoom-min="14">
            <caption
                fill="#333330"
                font-size="12"
                k="name"
                priority="-2"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="village" zoom-min="12">
            <caption
                fill="#333330"
                font-size="13"
                k="name"
                priority="5"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="town" zoom-min="8">
            <caption
                fill="#333330"
                font-size="15"
                font-style="bold"
                k="name"
                priority="15"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="6" zoom-min="6">
            <caption
                fill="#333330"
                font-size="14"
                font-style="bold"
                k="name"
                priority="25"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="7" zoom-min="7">
            <caption
                fill="#333330"
                font-size="15"
                font-style="bold"
                k="name"
                priority="25"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="9" zoom-min="8">
            <caption
                fill="#333330"
                font-size="17"
                font-style="bold"
                k="name"
                priority="25"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="11" zoom-min="10">
            <caption
                fill="#333330"
                font-size="19"
                font-style="bold"
                k="name"
                priority="25"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="city" zoom-max="13" zoom-min="12">
            <caption
                fill="#333330"
                font-size="20"
                font-style="bold"
                k="name"
                priority="25"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="3">
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="4" zoom-min="4">
            <caption
                fill="#000000"
                font-size="16"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="5" zoom-min="5">
            <caption
                fill="#000000"
                font-size="18"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
        <rule e="node" k="place" v="country" zoom-max="6" zoom-min="6">
            <caption
                fill="#000000"
                font-size="20"
                font-style="bold"
                k="name"
                priority="50"
                stroke="#FFFFFF"
                stroke-width="2.0"
            />
        </rule>
    </rule>

    <!-- ================ POIS ================ -->

    <!-- Natural landmarks -->
    <rule e="any" k="*" v="*">
        <rule e="node" k="natural" v="cave_entrance" zoom-min="14">
            <symbol
                id="cave"
                src="@drawable/cave#000000!"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="10"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="cave"
                />
            </rule>
        </rule>
        <rule e="node" k="natural" v="peak" zoom-min="9">
            <symbol
                id="peak"
                src="@drawable/triangle#000000!"
                symbol-height="12"
                symbol-width="12"
            />
            <caption
                fill="#000000"
                font-size="11"
                font-style="bold"
                k="name"
                position="above"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="peak"
            />
            <rule e="any" k="trail_sense_peak_elevation" v="yes" zoom-min="14">
                <caption
                    fill="#000000"
                    font-size="10"
                    k="ele"
                    position="below"
                    priority="30"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="peak"
                />
            </rule>
        </rule>
        <rule e="node" k="natural" v="volcano" zoom-min="11">
            <symbol
                id="volcano"
                src="@drawable/volcano#000000"
                symbol-height="12"
                symbol-width="12"
            />
            <caption
                fill="#000000"
                font-size="14"
                font-style="bold"
                k="name"
                position="above"
                priority="40"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="volcano"
            />
        </rule>
    </rule>

    <!-- Camping and shelter -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="amenity" v="shelter" zoom-min="14">
            <symbol
                id="shelter"
                src="@drawable/shelter#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="20"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="shelter"
                />
            </rule>
        </rule>
        <rule e="any" k="tourism" v="alpine_hut|wilderness_hut" zoom-min="12">
            <symbol
                id="alpine-hut"
                src="@drawable/ic_cabin#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="*" v="*" zoom-min="15">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="25"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="alpine-hut"
                />
            </rule>
            <rule e="any" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="11"
                    k="ele"
                    position="below"
                    priority="10"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="alpine-hut"
                />
            </rule>
        </rule>
        <rule e="any" k="tourism" v="camp_site" zoom-min="13">
            <symbol
                id="camping"
                src="@drawable/ic_category_shelter#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="node" k="*" v="*" zoom-min="15">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="18"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="camping"
                />
            </rule>
            <rule e="way" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    priority="18"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="camping"
                />
            </rule>
        </rule>
    </rule>

    <!-- Trail amenities -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="amenity" v="toilets" zoom-min="15">
            <symbol
                src="@drawable/ic_restrooms#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="tourism" v="picnic_site" zoom-min="15">
            <symbol
                src="@drawable/ic_picnic#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="telephone" zoom-min="15">
            <symbol
                src="@drawable/ic_phone#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="drinking_water" zoom-min="16">
            <symbol
                src="@drawable/ic_category_water#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="parking" zoom-min="16">
            <symbol
                src="@drawable/ic_car#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="ranger_station" zoom-min="15">
            <symbol
                src="@drawable/ranger_station#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
    </rule>

    <!-- Tourism and trail information -->
    <rule e="any" k="*" v="*">
        <rule e="node" k="tourism" v="viewpoint" zoom-min="15">
            <symbol
                id="viewpoint"
                src="@drawable/ic_binoculars#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="natural" v="~" zoom-min="17">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="viewpoint"
                />
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="ele"
                    position="above"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="viewpoint"
                />
            </rule>
        </rule>
        <rule e="any" k="tourism" v="information" zoom-min="16">
            <symbol
                src="@drawable/ic_info#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
    </rule>

</rendertheme>
