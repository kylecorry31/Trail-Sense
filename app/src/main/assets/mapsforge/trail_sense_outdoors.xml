    >
        <rule e="node" k="natural" v="wetland|beach" zoom-min="15">
            <caption
                fill="#000000"
                font-family="serif"
                font-size="10"
                font-style="italic"
                k="name"
                stroke="#FFFFFF"
                stroke-width="0.1"
            />
        </rule>
    </rule> -->

