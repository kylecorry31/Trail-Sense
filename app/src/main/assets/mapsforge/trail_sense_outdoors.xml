<?xml version="1.0" encoding="UTF-8"?>
<!-- https://github.com/mapsforge/mapsforge/blob/master/mapsforge-map-writer/src/main/config/tag-mapping.xml -->
<rendertheme
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    map-background="#C4CCB0"
    map-background-outside="#C4CCB0"
    version="5"
    xmlns="http://mapsforge.org/renderTheme"
    xsi:schemaLocation="http://mapsforge.org/renderTheme https://raw.githubusercontent.com/mapsforge/mapsforge/master/resources/renderTheme.xsd"
>

    <!-- ================ NATURAL / LANDUSE ================ -->

    <rule e="way" k="natural|landuse" v="sea" zoom-min="0">
        <area fill="#AAD3DF" />
    </rule>

    <!-- TODO: Reef -->

    <!-- Land -->
    <rule e="way" k="natural" v="nosea|land" zoom-min="0">
        <area fill="#C4CCB0" />
    </rule>

    <!-- Barren Land (Rock/Sand/Clay) -->

    <!-- Sand -->
    <rule
        e="way"
        k="natural|landuse|surface"
        v="beach|sand|desert|dune"
        zoom-min="6"
    >
        <area fill="#E8E1B6" />
    </rule>

    <!-- Rock -->
    <!-- TODO: Natural beach w/ surface=pebbles -->
    <!-- TODO: Shoal treated like reef? -->
    <rule
        e="way"
        k="natural|landuse|surface"
        v="scree|shingle|gravel|quarry|bare_rock|pebbles|stones|shoal|blockfield|rock"
        zoom-min="6"
    >
        <area fill="#CAC3B8" />
    </rule>

    <!-- Clay -->
    <rule e="way" k="natural|wetland" v="mud" zoom-min="6">
        <!-- TODO: Use another color -->
        <area fill="#CAC3B8" />
    </rule>

    <!-- Tundra -->
    <rule e="way" k="natural" v="tundra|fell" zoom-min="6">
        <!-- TODO: Use another color -->
        <area fill="#BBC6A8" />
    </rule>

    <!-- Grassland/Herbaceous -->
    <rule
        e="way"
        k="natural|landuse|surface|leisure"
        v="grassland|meadow|grass|greenfield|recreation_ground|garden|park|village_green|greenery|farmland|allotments"
        zoom-min="6"
    >
        <area fill="#BBC6A8" />
    </rule>

    <rule e="way" k="natural" v="wetland" zoom-min="6">
        <rule e="way" k="wetland" v="marsh|saltmarsh|wet_meadow|reedbed">
            <area fill="#BBC6A8" />
        </rule>
    </rule>

    <!-- Scrub -->
    <rule
        e="way"
        k="natural|landuse"
        v="heath|scrub|shrub|vineyard"
        zoom-min="6"
    >
        <!-- TODO: Use another color -->
        <area fill="#BBC6A8" />
    </rule>

    <!-- Trees -->
    <rule e="way" k="natural|landuse" v="wood|forest|orchard" zoom-min="6">
        <area fill="#B5C6A2" />
    </rule>

    <!-- Swamps and mangroves also gets forest styling -->
    <!-- TODO: Separate styling for mangroves since it is both shrub and trees -->
    <rule e="way" k="natural" v="wetland" zoom-min="6">
        <rule e="way" k="wetland" v="swamp|mangrove">
            <area fill="#B5C6A2" />
        </rule>
    </rule>

    <!-- Human -->
    <rule
        e="way"
        k="landuse|amenity"
        v="brownfield|commercial|construction|factory|greenfield|industrial|landfill|military|railway|retail|residential|parking"
        zoom-min="14"
    >
        <area fill="#C4C4BC" />
    </rule>

    <rule e="way" k="building|shop" v="*" zoom-min="15">
        <area fill="#B7B7AE" />
        <line stroke="#22000000" stroke-width="0.1" />
    </rule>

    <!-- Wetlands -->
    <!-- TODO: wetland type might matter -->
    <rule e="way" k="natural" v="marsh|wetland" zoom-min="6">
        <area fill="#7FC4D1BB" />
        <area
            src="@drawable/swamp_pattern#8FB47A!"
            symbol-height="24"
            symbol-width="24"
        />
    </rule>

    <!-- Major bodies of water -->

    <rule e="way" k="natural|landuse" v="water|basin|reservoir" zoom-min="0">
        <area fill="#AAD3DF" />
        <line stroke="#4E8CA8" stroke-width="0.3" />
    </rule>

    <rule e="way" k="waterway" v="river|riverbank" zoom-min="8">
        <line stroke="#4E8CA8" stroke-width="1.0" />
    </rule>

    <!-- Minor bodies of water -->
    <rule e="way" k="lock" v="yes" zoom-min="14">
        <line stroke="#4E8CA8" stroke-width="0.5" />
    </rule>

    <rule e="way" k="waterway" v="canal|drain|stream" zoom-min="10">
        <line stroke="#4E8CA8" stroke-width="0.5" />
    </rule>

    <!-- TODO: waterway dam -->
    <!-- TODO: natural coastline -->

    <!-- Perennial Ice/Snow -->
    <rule e="way" k="natural" v="glacier" zoom-min="8">
        <area fill="#F5F4F2" />
    </rule>

    <!-- Public lands: https://wiki.openstreetmap.org/wiki/United_States/Public_lands -->

    <rule
        e="way"
        k="boundary|leisure"
        v="protected_area|national_park|nature_reserve"
        zoom-min="10"
    >
        <rule e="way" k="access" v="~|private|no">
            <line dy="1.0" stroke="#6675a35b" stroke-width="2.0" />
            <line stroke="#47742c" stroke-width="0.5" />
        </rule>
    </rule>

    <rule
        e="way"
        k="leisure"
        v="recreation_ground|park"
        zoom-min="10"
        closed="yes"
    >
        <rule e="way" k="access" v="~|private|no">
            <area fill="#6675a35b" />
        </rule>
    </rule>

    <!-- Water control features -->
    <rule e="way" k="lock" v="yes|true" zoom-min="14">
        <line stroke="#8E8E87" stroke-linecap="square" stroke-width="2.0" />
        <line stroke="#AAD3DF" stroke-linecap="butt" stroke-width="1.6" />
    </rule>

    <rule e="way" k="waterway" v="weir" zoom-min="14">
        <line stroke="#8E8E87" stroke-width="0.7" />
        <line
            stroke="#C8C0B0"
            stroke-dasharray="5,1"
            stroke-linecap="butt"
            stroke-width="0.7"
        />
    </rule>

    <rule e="way" k="waterway" v="dam" zoom-min="14">
        <line stroke="#8E8E87" stroke-width="1" />
        <line
            stroke="#C8C0B0"
            stroke-dasharray="10,1"
            stroke-linecap="butt"
            stroke-width="1"
        />
        <rule closed="yes" e="any" k="*" v="*">
            <area fill="#C8C0B0" />
        </rule>
    </rule>

    <!-- Barriers -->
    <rule e="way" k="barrier" v="fence" zoom-min="15">
        <line
            stroke="#7B7480"
            stroke-dasharray="2,2"
            stroke-linecap="butt"
            stroke-width="0.1"
        />
    </rule>

    <rule e="way" k="barrier|building" v="wall|city_wall" zoom-min="15">
        <line stroke="#7B7480" stroke-linecap="round" stroke-width="0.3" />
        <line
            stroke="#D6D2C8"
            stroke-dasharray="5,1"
            stroke-linecap="butt"
            stroke-width="0.15"
        />
    </rule>

    <rule e="way" k="barrier" v="retaining_wall" zoom-min="15">
        <line stroke="#7B7480" stroke-linecap="round" stroke-width="0.5" />
        <line
            stroke="#D6D2C8"
            stroke-dasharray="4,1"
            stroke-linecap="butt"
            stroke-width="0.3"
        />
    </rule>

    <!-- ================ WAY -> HIGHWAY ================ -->

    <!-- Access roads -->
    <rule e="way" k="highway" v="service|services|raceway" zoom-min="15">
        <line stroke="#AFAFA8" stroke-width="0.6" />
        <line stroke="#D6D2C8" stroke-width="0.4" />
    </rule>

    <!-- Minor roads -->
    <rule e="way" k="highway" v="byway|track" zoom-min="12">
        <line stroke="#9A6A3A" stroke-width="1.0" />
        <line stroke="#D8C89A" stroke-width="0.8" />
        <line
            stroke="#9A6A3A"
            stroke-width="0.6"
            stroke-dasharray="1,2"
            scale="all"
        />
    </rule>

    <rule
        e="way"
        k="highway"
        v="residential|road|tertiary|tertiary_link|bus_guideway|living_street|construction|unclassified"
        zoom-min="12"
    >
        <line stroke="#AFAFA8" stroke-width="1.2" />
        <line stroke="#D6D2C8" stroke-width="1.0" />
    </rule>

    <!-- Major roads -->
    <rule e="way" k="highway" v="secondary|secondary_link" zoom-min="11">
        <line stroke="#8E8E87" stroke-width="1.6" />
        <line stroke="#AFAFA8" stroke-width="1.4" />
    </rule>

    <rule e="way" k="highway" v="primary|primary_link" zoom-min="11">
        <line stroke="#8E8E87" stroke-width="1.8" />
        <line stroke="#AFAFA8" stroke-width="1.6" />
    </rule>

    <rule
        e="way"
        k="highway"
        v="trunk|trunk_link|motorway|motorway_link"
        zoom-min="10"
    >
        <line stroke="#8E8E87" stroke-width="2.2" />
        <line stroke="#AFAFA8" stroke-width="2.0" />
    </rule>

    <!-- Trails -->
    <rule
        e="way"
        k="highway"
        v="path|pedestrian|footway|cycleway|bridleway|steps"
        zoom-min="12"
    >
        <line
            stroke="#6B3F1D"
            stroke-width="0.5"
            stroke-dasharray="1,1"
            scale="all"
        />
    </rule>

    <!-- ================ LABELS ================ -->

    <!-- Natural / landuse labels -->

