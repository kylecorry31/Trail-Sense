    </rule>

    <!-- Camping and shelter -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="amenity" v="shelter" zoom-min="14">
            <!-- TODO: shelter_type -->
            <symbol
                id="shelter"
                src="@drawable/ic_category_shelter#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <caption
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                priority="10"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="shelter"
            />
        </rule>
        <rule e="any" k="tourism" v="alpine_hut|wilderness_hut" zoom-min="12">
            <symbol
                id="alpine-hut"
                src="@drawable/ic_cabin#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <caption
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="name"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="alpine-hut"
            />
            <caption
                fill="#000000"
                font-size="12"
                font-style="bold"
                k="ele"
                stroke="#FFFFFF"
                stroke-width="2.0"
                symbol-id="alpine-hut"
            />
        </rule>
        <rule e="any" k="tourism" v="camp_site" zoom-min="13">
            <symbol
                id="camping"
                src="@drawable/ic_category_shelter#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="node" k="*" v="*" zoom-min="15">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="camping"
                />
            </rule>
            <rule e="way" k="*" v="*" zoom-min="16">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="camping"
                />
            </rule>
        </rule>
    </rule>

    <!-- Trail amenities -->
    <rule e="any" k="*" v="*">
        <rule e="any" k="amenity" v="toilets" zoom-min="15">
            <symbol
                src="@drawable/ic_restrooms#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="tourism" v="picnic_site" zoom-min="15">
            <symbol
                src="@drawable/ic_picnic#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <!--        <rule e="node" k="amenity" v="bench" zoom-min="15">-->
        <!--            <symbol-->
        <!--                src="@drawable/bench#000000"-->
        <!--                symbol-height="16"-->
        <!--                symbol-width="16"-->
        <!--            />-->
        <!--        </rule>-->
        <rule e="any" k="amenity" v="telephone" zoom-min="15">
            <symbol
                src="@drawable/ic_phone#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="drinking_water" zoom-min="16">
            <symbol
                src="@drawable/ic_category_water#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="parking" zoom-min="16">
            <symbol
                src="@drawable/ic_car#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule e="any" k="amenity" v="ranger_station" zoom-min="15">
            <symbol
                src="@drawable/ranger_station#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
    </rule>

    <!-- Tourism and trail information -->
    <rule e="any" k="*" v="*">
        <rule e="node" k="tourism" v="viewpoint" zoom-min="15">
            <symbol
                id="viewpoint"
                src="@drawable/ic_binoculars#000000"
                symbol-height="16"
                symbol-width="16"
            />
            <rule e="any" k="natural" v="~" zoom-min="17">
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="name"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="viewpoint"
                />
                <caption
                    fill="#000000"
                    font-size="12"
                    font-style="bold"
                    k="ele"
                    position="above"
                    stroke="#FFFFFF"
                    stroke-width="2.0"
                    symbol-id="viewpoint"
                />
            </rule>
        </rule>
        <rule e="any" k="tourism" v="information" zoom-min="16">
            <symbol
                src="@drawable/ic_info#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
        <rule
            e="any"
            k="historic|building"
            v="ruins|archaeological_site"
            zoom-min="15"
        >
            <symbol
                src="@drawable/ic_ruins#000000"
                symbol-height="16"
                symbol-width="16"
            />
        </rule>
    </rule>

    <!-- Barrier POIs -->
    <!-- TODO: Icon needed -->
    <!-- <rule e="any" k="barrier" v="*" zoom-min="17">
        <rule e="node" k="barrier" v="gate">
            <symbol src="" />
        </rule>
    </rule> -->

    <!-- POI labels -->
    <rule
        e="any"
        k="tourism|amenity|man_made|historic"
        v="information|memorial|windmill|ruins|archaeological_site"
        zoom-min="18"
    >
        <caption
            fill="#000000"
            font-size="12"
            font-style="bold"
            k="name"
            position="above"
            stroke="#FFFFFF"
            stroke-width="2.0"
        />
    </rule>

    <rule e="any" k="barrier" v="*" zoom-min="18">
        <caption
            fill="#000000"
            font-size="12"
            font-style="bold"
            k="name"
            position="above"
            stroke="#FFFFFF"
            stroke-width="2.0"
        />
    </rule>

</rendertheme>
